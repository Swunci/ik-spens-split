model Group {
	groupId String @id @default(uuid())
	groupName String
	currency String
	memberNames String[]
	transactions Transaction[]
	history History[]
	paidDebts PaidDebt[]
}

model Transaction {
	group Group @relation(fields: [groupId], references: [groupId])
	groupId String

	transactionId String @id @default(uuid())
	payer String
	description String
	amount Float
	split Json
	date DateTime
	type String
	currency String
}

model History {
	group Group @relation(fields: [groupId], references: [groupId])
	groupId String
	historyId String @id @default(uuid())
	details Json
	createdDate DateTime
}

model PaidDebt {
	group Group @relation(fields: [groupId], references: [groupId])
	groupId String
	debtId String @id @default(uuid())
	creditor String
	debtor String
	amount Float
	date DateTime @default(now())
	currency String
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}