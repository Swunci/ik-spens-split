model Group {
	groupId String @id @default(uuid())
	groupName String
	currency String
	memberNames String[]
	transactions Transaction[]
	history History[]
	paidDebts PaidDebt[]
}

model Transaction {
	groupId String
	group Group @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

	transactionId String @id @default(uuid())
	payer String
	description String
	amount Float
	split Json
	date DateTime
	type String
	currency String

	@@unique([groupId, transactionId])
}

model History {
	groupId String
	group Group @relation(fields: [groupId], references: [groupId], onDelete: Cascade)
	
	historyId String @id @default(uuid())
	table String
	action String
	details Json
	createdDate DateTime

	@@unique([groupId, historyId])
}

model PaidDebt {
	groupId String
	group Group @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

	debtId String @id @default(uuid())
	creditor String
	debtor String
	amount Float
	date DateTime @default(now())
	currency String

	@@unique([groupId, debtId])
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}