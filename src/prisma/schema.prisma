model Group {
	groupId String @id @default(uuid())
	groupName String @db.VarChar(100)
	currency String @db.Char(3)
	members Member[]
	transactions Transaction[]
	history History[]
	paidDebts PaidDebt[]
	comments Comment[]
	createdDate DateTime
  level Int @default(0)
}

model Member {
  groupId String
	group Group @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

  memberId String @id @default(uuid())
  memberName String @db.VarChar(35)

  paidTransactions Transaction[]
  shareCosts ShareCost[]

  paidDebtsAsCreditor PaidDebt[] @relation("creditor")
  paidDebtsAsDebtior PaidDebt[] @relation("debtor")

  comments Comment[]

  @@unique([groupId, memberName])
}

model ShareCost {
  memberId String
  member Member @relation(fields: [memberId], references: [memberId], onDelete: Cascade)

  transactionId String
  transaction Transaction @relation(fields: [transactionId], references: [transactionId], onDelete: Cascade)

  shareCost Decimal @db.Decimal(36, 18)
  weight Int @default(0)

  @@id([memberId, transactionId])
}

model Transaction {
	groupId String
  group Group @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

  payerId String
  member Member @relation(fields: [payerId], references: [memberId], onDelete: Cascade)

	transactionId String @id @default(uuid())
	description String @db.VarChar(1000)
	amount Decimal @db.Decimal(36, 18)
	date DateTime @db.Date
	type String @db.VarChar(10)
	currency String @db.Char(3)
  splitType String @db.VarChar(10)

  shareCosts ShareCost[]

	@@unique([groupId, transactionId])
}

model History {
	groupId String
	group Group @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

	historyId String @id @default(uuid())
	table String
	action String
	details Json
	createdDate DateTime

	@@unique([groupId, historyId])
}

model PaidDebt {
	groupId String
	group Group @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

	creditor String
	debtor String
  creditorMember Member @relation("creditor", fields: [creditor], references: [memberId], onDelete: Cascade)
  debtorMember Member @relation("debtor", fields: [debtor], references: [memberId], onDelete: Cascade)

	debtId String @id @default(uuid())
	amount Decimal @db.Decimal(36, 18)
	date DateTime @default(now())
	currency String @db.Char(3)

	@@unique([groupId, debtId])
}

model Comment {
	groupId String
	group Group @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

  commenterId String
  member Member @relation(fields: [commenterId], references: [memberId], onDelete: Cascade)

	commentId String @id @default(uuid())
	comment String @db.VarChar(10000)
	createdDate DateTime

	@@unique([groupId, commentId])
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}